{
    "manifest_version": 3,
    "name": "Real Sports Predictions",
    "version": "1.0",
    "description": "Calculates expected value for sports betting odds on sportsbooks to help users make decisions on predictions in the Real Sports app.",
    "permissions": [
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "https://realsports.io/*",
        "https://sportsbook.fanduel.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://realsports.io/*"],
            "js": ["content_real.js"],
            "run_at": "document_idle"
        },
        {
            "matches": ["https://sportsbook.fanduel.com/*"],
            "js": ["content_fd.js"],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
